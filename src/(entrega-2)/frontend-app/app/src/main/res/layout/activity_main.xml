<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp"
    android:background="@color/white"
    tools:context=".UI.MainActivity">

    <View
        android:id="@+id/topBackground"
        android:layout_width="match_parent"
        android:layout_height="210dp"
        android:background="@drawable/top_bg"
        android:elevation="4dp"
        android:outlineProvider="background"
        app:layout_constraintBottom_toTopOf="@id/contentLayout"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/contour"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="30dp"
        android:elevation="10dp"
        android:src="@drawable/icon"
        app:layout_constraintBottom_toBottomOf="@id/topBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/topBackground" />

    <TextView
        android:id="@+id/txtWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:elevation="5dp"
        android:text="Bem-Vindo(a),"
        android:textColor="@color/white"
        android:textSize="35sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/contour"
        app:layout_constraintStart_toEndOf="@id/contour"
        app:layout_constraintTop_toTopOf="@id/contour"
        app:layout_constraintVertical_bias="0.15" />

    <TextView
        android:id="@+id/txtName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Insira seu Nome"
        android:textColor="@color/white"
        android:textSize="30sp"
        android:elevation="5dp"
        app:layout_constraintTop_toBottomOf="@id/txtWelcome"
        app:layout_constraintStart_toStartOf="@id/txtWelcome" />

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="20dp"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/topBackground"
        app:layout_constraintBottom_toTopOf="@id/menu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- HEADER (semana) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:contentDescription="Anterior"
                android:onClick="previousWeekAction"
                android:rotation="180"
                android:scaleType="fitStart"
                android:src="@drawable/brown_chevron"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/monthYearTV"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Fev 2026"
                android:textFontWeight="600"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textSize="20sp" />

            <ImageButton
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:scaleType="fitEnd"
                android:onClick="nextWeekAction"
                android:contentDescription="Próximo"
                android:background="?attr/selectableItemBackground"
                android:src="@drawable/brown_chevron" />

        </LinearLayout>

        <!-- CALENDÁRIO -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/calendarRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:clipChildren="false"
            android:clipToPadding="false"/>


        <TextView
            android:id="@+id/txtTodayExercise"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingTop="18dp"
            android:text="Exercício de hoje"
            android:textSize="18sp"
            android:textFontWeight="700"
            android:layout_marginBottom="10dp"
            android:textColor="@color/black" />

        <!-- TASKS -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:nestedScrollingEnabled="false" />

        <Button
            android:id="@+id/btnStartWorkout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INICIAR EXERCÍCIO"
            android:background="@drawable/bg_button_ag_in"
            android:textColor="@color/white"
            android:layout_margin="16dp"
            app:cornerRadius="8dp"
            android:visibility="visible" />

    </LinearLayout>

    <include
        android:id="@+id/menu"
        layout="@layout/menu"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>