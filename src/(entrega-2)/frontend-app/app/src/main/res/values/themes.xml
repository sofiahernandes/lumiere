<resources>
    <style name="Theme.Projeto8" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">#2F8394</item>
        <item name="android:statusBarColor">#2F8394</item>
        <item name="android:navigationBarColor">#2F8394</item>
